import { Button, VerticalBox, LineEdit } from "std-widgets.slint";
import { ValidatedInput } from "./widgets/validated_input.slint";

export component AppWindow inherits Window {

    in-out property <bool> first-start: true;

    out property <length> height_: 195pt;
    out property <length> width_: 210pt;

    in-out property <int> active-page: 0;

    // data
    in-out property <string> username: "";
    in-out property <string> ip: "";
    in-out property <string> port: "";
    // errors
    in-out property <bool> username_error: false;
    in-out property <bool> ip_error: false;
    in-out property <bool> port_error: false;

    callback validate_username(text: string);
    callback validate_ip(text: string);
    callback validate_port(text: string);

    callback validate_connection_page;
    callback validate_username_page;

    callback client_mode();
    callback server_mode();

    title: "SimpleChat";

    // making it appear in the same way as linux (debian), since width and height seems to be not enough.
    preferred-height: height_;
    preferred-width: width_;
    max-width: width_;
    max-height: height_;
    min-width: width_;
    min-height: height_;

    changed active-page  => {
        if (active-page == 0) {ip_w.focus-text()}
        if (active-page == 1) {username_w.focus-text()}
    }


    // First Layout
    VerticalLayout {

        opacity: root.first-start ? 0 : 1;
        animate opacity { duration: 1500ms; easing: ease-in-out; delay: 250ms;}
        //


        // page change animation
        x: root.active-page == 0 ? 0pt : -root.width;
        animate x { duration: 250ms; easing: ease-in-out; }
        //

        alignment: center;
        spacing: 20pt;

        // Title layout
        VerticalLayout {
            spacing: 5pt;
            Text {
                text: "Welcome Back!";
                font-size: 16pt;
                horizontal-alignment: center;
            }
            Text {
                text: "Let's begin with connection info:";
                font-size: 11pt;
                horizontal-alignment: center;
            }
        }
        //


        // Data layout
        HorizontalLayout {
            alignment: center;
            VerticalLayout {
                spacing: 8pt;
                width: 140pt;

                ip_w := ValidatedInput {  // w = widget
                    text-text <=> ip;
                    has-error: ip_error;
                    placeholder-text: "IP Address";
                    height-text: 22pt;
                    accepted(text) => {validate_ip(text); port_w.focus-text();}
                    focus_out(text) => {validate_ip(text)}
                }
                port_w := ValidatedInput {
                    has-error: port_error;
                    text-text <=> port;
                    placeholder-text: "Port";
                    height-text: 22pt;
                    accepted(text) => {button_w.clicked()}
                    focus_out(text) => {validate_port(text)}
                }
                button_w := Button {
                    text: "Continue";
                    primary: true;
                    height: 24pt;
                    clicked => {validate_connection_page();}
                }
            }
        }
        //
    }



    // Second Layout. First index
    VerticalLayout {
        x: root.active-page == 1 ? 0pt : root.width;
        animate x { duration: 250ms; easing: ease-in-out; }

        alignment: center;
        spacing: 20pt;

        // Title layout
        VerticalLayout {
            spacing: 5pt;
            Text {
                text: "Let people know your name";
                font-size: 15.8pt;
                horizontal-alignment: center;
            }
        }

        // Data layout
        HorizontalLayout {
            alignment: center;
            VerticalLayout {
                spacing: 8pt;
                width: 140pt;

                username_w := ValidatedInput {
                    has-error: username_error;
                    text-text <=> username;
                    placeholder-text: "Username";
                    height-text: 22pt;
                    horizontal-alignment: center;
                    accepted(text) => {cont_w.clicked()}
                    focus_out(text) => {validate_username(text)}
                }

                HorizontalLayout {
                    spacing: 3pt;
                    Button {
                        width: 50%;
                        text: "Return";
                        height: 24pt;
                        clicked => { root.active-page = 0; }
                    }
                    cont_w := Button {
                        width: 50%;
                        text: "Continue";
                        primary: true;
                        height: 24pt;
                        clicked => { validate_username_page()}
                    }

                }
            }
        }
    }


    // Third Layout.
    VerticalLayout {
        // page chnage animation
        y: root.active-page == 2 ? 0pt : root.height;
        animate y { duration: 250ms; easing: ease-in-out; }

        alignment: center;
        spacing: 20pt;

        // Title layout
        VerticalLayout {
            spacing: 5pt;
            Text {
                text: "Final step";
                font-size: 16pt;
                horizontal-alignment: center;
            }
            Text {
                text: "Let's choose the role";
                font-size: 11pt;
                horizontal-alignment: center;
            }
        }

        // Data layout
        HorizontalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 8pt;
                width: 140pt;

                Button {
                    text: "Client";
                    height: 24pt;
                    primary: true;
                    clicked => { client_mode()}
                }
                Button {
                    text: "Server";
                    height: 24pt;
                    primary: true;
                    clicked => {server_mode()}
                }
            }
        }
    }
}
